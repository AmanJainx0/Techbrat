# Django secret key
DJANGO_SECRET_KEY=replace-with-your-secret-key

# Debug mode
DEBUG=True

# Hosts
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://your-railway-app.railway.app

# Database settings (Railway MySQL)
DB_ENGINE=mysql
MYSQL_DATABASE=your_db_name
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_HOST=your_db_host
MYSQL_PORT=your_db_port

# Optional DATABASE_URL support
# DATABASE_URL=mysql://user:password@host:port/database

# Optional alternate env names
# MYSQLDATABASE=your_db_name
# MYSQLUSER=your_db_user
# MYSQLPASSWORD=your_db_password
# MYSQLHOST=your_db_host
# MYSQLPORT=your_db_port

# OpenRouter AI settings
OPENROUTER_API_KEY=your_api_key
OPENROUTER_MODEL=google/gemma-4-26b-a4b
